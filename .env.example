# App
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Dependency statuses
POSTGRES_STATUS=ready
QDRANT_STATUS=ready

# PostgreSQL
POSTGRES_DB=rust_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/rust_assistant
DATABASE_READ_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/rust_assistant
POSTGRES_ECHO=false
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=10

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=rust-assistant-embeddings
QDRANT_VECTOR_SIZE=640
QDRANT_DISTANCE=cosine
QDRANT_UPSERT_BATCH_SIZE=256

# LLM
LLM_PROVIDER=
LLM_MODEL=

# Embeddings
EMBEDDING_MODEL=microsoft/harrier-oss-v1-270m
EMBEDDING_BASE_URL=http://tei-embedder:80
EMBEDDING_NORMALIZE=true
EMBEDDING_MAX_BATCH_ITEMS=8
EMBEDDING_REQUEST_TIMEOUT_SECONDS=120
EMBEDDING_POOLING=mean
EMBEDDING_MAX_BATCH_TOKENS=1024
EMBEDDING_MAX_CONCURRENT_REQUESTS=8

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BASE_URL=http://tei-reranker:80

# Ingest
RUST_DOCS_RAW_DIR=D:/path/to/rust-docs
INGEST_MAX_CHUNK_CHARS=1400
INGEST_MIN_CHUNK_CHARS=180

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Public / Proxy
PUBLIC_BASE_URL=https://localhost
