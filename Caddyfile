{$PUBLIC_BASE_URL} {
    encode gzip zstd

    reverse_proxy backend:{$PORT} {
        health_uri /health
        health_interval 10s
        health_timeout 3s
    }

    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer-when-downgrade"
    }

    log {
        output stdout
        format console
    }
}

